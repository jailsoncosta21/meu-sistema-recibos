import streamlit as st
import gspread
from fpdf import FPDF
from google.oauth2.service_account import Credentials

st.set_page_config(page_title="Gestão de Recibos", page_icon="🏠")
st.title("🏠 Gerador de Recibos")

def conectar_planilha():
    # Acessa os dados configurados no Secrets do Streamlit Cloud
    creds_dict = st.secrets["gcp_service_account"]
    creds = Credentials.from_service_account_info(creds_dict)
    scopes = ["https://www.googleapis.com/auth/spreadsheets", "https://www.googleapis.com/auth/drive"]
    creds = creds.with_scopes(scopes)
    return gspread.authorize(creds)

if st.button("Gerar Recibo via Planilha"):
    try:
        # Conexão
        gc = conectar_planilha()
        sh = gc.open("Sistema de Gestão Imobiliária Completo VFinal")
        aba_recibo = sh.worksheet("Recibo")
        
        # Exemplo de leitura (ajuste conforme necessário)
        dados = aba_recibo.row_values(2) 
        
        # Geração do PDF
        pdf = FPDF()
        pdf.add_page()
        pdf.set_font("Arial", 'B', 16)
        pdf.cell(200, 10, txt="RECIBO DE PAGAMENTO", ln=True, align='C')
        pdf.ln(10)
        
        pdf.set_font("Arial", size=12)
        pdf.cell(200, 10, txt=f"Dados: {dados}", ln=True)
        
        pdf_output = pdf.output(dest='S').encode('latin-1')
        
        st.success("Recibo gerado com sucesso!")
        st.download_button("📥 Baixar PDF", data=pdf_output, file_name="Recibo.pdf", mime="application/pdf")
        st.balloons()
        
    except Exception as e:
        st.error(f"Erro ao acessar Google Sheets: {e}")
